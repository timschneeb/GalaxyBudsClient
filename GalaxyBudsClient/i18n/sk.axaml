    <!--Connection lost page-->
    <sys:String x:Key="connlost">Spojenie stratené</sys:String>
    <sys:String x:Key="connlost_header">Nie je možné nadviazať spojenie</sys:String>
    <sys:String x:Key="connlost_connect">Pripojiť</sys:String>
    <sys:String x:Key="connlost_connecting">Pripájam...</sys:String>
    <sys:String x:Key="connlost_troubleshoot">Riešenie problémov</sys:String>
    <sys:String x:Key="connlost_troubleshoot_title">Ako riešiť problémy s pripojením</sys:String>
    <sys:String x:Key="connlost_troubleshoot_content">Uistite sa, že sa oficiálna aplikácia Wearable spoločnosti Samsung pre Galaxy Buds nepokúŠa pripojiť ku slúchadlám na pozadí.
V opačném prípade budete mať veľmi často problémy so stratou pripojenia, pretože sa ich aplikácia bude opakovane pokúšať získať kontrolu nad slúchadlami.

K odstráneniu tohto problému môžete zvoliť jedno z týchto riešení:

• Zrušte párovanie slúchadiel s aplikáciou Wearable. (V aplikácii Wearable otvorte ponuku, vyberte možnosť "Spravovať zariadenie" a odstráňte slúchadlá zo zoznamu).

• Odinštalujte doplnok Galaxy Buds pre aplikáciu Samsung Wearable.

• Pomocou aplikácie, ako je "Hail" alebo "Ice Box", dočasne zamrazte oficiálny doplnok Galaxy Buds pre aplikáciu Samsung Wearable, aby ste mu zabránili v spustení.
    </sys:String>

    <!-- Pairing mode -->
    <sys:String x:Key="connlost_disconnected">Zariadenie je odpojené</sys:String>
    <sys:String x:Key="pairingmode_done">Slúchadlá boli prepnuté do režimu párovania a sú teraz odpojené od tohto zariadenia.</sys:String>

    <!--Firmware update disclaimer-->
    <sys:String x:Key="fw_disclaimer">Vylúčenie zodpovednosti</sys:String>
    <sys:String x:Key="fw_disclaimer_desc">Tento nástroj pre aktualizáciu firmwaru je presná replika oficiálneho aktualizátora nájdeného v oficiálnej aplikácii pre Android od spoločnosti Samsung. Túto implementáciu som dôkladne otestoval za rôznych okolností (normálne používanie, strata pripojenia, zámerne poškodené pakety Bluetooth, ...), bez toho aby došlo k akýmkoľvek problémom. Napriek tomu, nebudem viesť žiadnu zodpovednosť pokiaľ sa niečo pokazí, nakoľko aktualizácia firmwaru mení dôležité súčasti systému a malo by sa s nimi zachádzať opatrne.

DOWNGRADE: Pri prechode na staršie verzie firmwaru som nenarazil na problémy, ale napriek tomu môžu nastať a môžu spôsobiť neočakávané problémy. Obnovenie továrnych nastavení po downgrade je odporúčané ale väčšinou nie je nutné.
VLASTNÉ NAHRÁVANIE: Taktiež je Vám umožnené načitať súbor firmwaru z VaŠeho disku. NENAHRÁVAJTE do svojho zariadenia firmware určený pre INÉ modely.

Táto aplikácia podlieha licencii GPLv3. Jej používaním prijímate licenciu a jej vylúčenia zodpovednosti. Potvrďte stlaČením tlačidla 'Pokračovať'.</sys:String>

    <!--Firmware selection-->
    <sys:String x:Key="fw_select_header">Aktualizácia firmwaru</sys:String>
    <sys:String x:Key="fw_select_downgrade">Povoliť downgrade firmwaru</sys:String>
    <sys:String x:Key="fw_select_downgrade_desc">Vypne kontrolu verzií a zobrazí staršie firmwary v zozname (môže spôsobiť neočakávané problémy; len pre pokročilých užívateľov)</sys:String>
    <sys:String x:Key="fw_select_install">Inštalácia firmwaru</sys:String>
    <sys:String x:Key="fw_select_install_short">Inštalovať</sys:String>
    <sys:String x:Key="fw_select_from_disk">Vybrať firmware z disku...</sys:String>
    <sys:String x:Key="fw_select_from_disk_short">Vybrať</sys:String>
    <sys:String x:Key="fw_select_refresh">Obnoviť</sys:String>
    <sys:String x:Key="fw_select_unsupported_selection">Neplatný výber. Vyberte prosím kompatibilnú položku zo zoznamu.</sys:String>
    <sys:String x:Key="fw_select_downloading">Sťahovanie...</sys:String>
    <sys:String x:Key="fw_select_net_error">Nepodarilo sa komunikovať so serverom. V tejto chvíli nie je možné stiahnuť firmware.</sys:String>
    <sys:String x:Key="fw_select_net_index_error">Nepodarilo sa komunikovať so serverom. V tejto chvíli nie je možné stiahnuť index firmwaru.</sys:String>
    <sys:String x:Key="fw_select_http_error">Kód chyby HTTP:</sys:String>
    <sys:String x:Key="fw_select_unknown_build">Neznámy názov zostavy</sys:String>
    <sys:String x:Key="fw_select_no_results_short">Nenašli sa žiadne aktualizácie</sys:String>
    <sys:String x:Key="fw_select_verify_fail">Nepodarilo sa overiť firmware</sys:String>
    <sys:String x:Key="fw_select_verify_model_mismatch_fail">Detekovaná nezhoda modelu zariadenia! Prenos firmwaru bol zrušený.

Pokúšate sa nahrať firmware pre {0} na {1}. To môže slúchadlá natrvalo zablokovať.</sys:String>
    <sys:String x:Key="fw_select_confirm">Chystáte sa flashnúť '{0}' na Vaše zariadenie '{1}'</sys:String>
    <sys:String x:Key="fw_select_confirm_desc">Uistite sa, že sú tieto informácie správn, inak stlačte 'Zrušiť' a skontrolujte nastavenia.

Pokiaľ je to možné, uistite sa pred spustením, že sú pripojené obe slúchadlá. Nebude spôsobovať žiadne problémy, pokiaľ pripojenie behom prenosu aktualizácie zlyhá. V takomto prípade slúchadlá automaticky zrušia proces prenosu a ukončia režim aktualizácie firmwaru.

Aktualizáciu spustíte stlačením tlačidla 'Pokračovať'.</sys:String>

    <!--Firmware transfer-->
    <sys:String x:Key="fw_upload_header">Inštalácia firmwaru...</sys:String>
    <sys:String x:Key="fw_upload_progress_session">Vytvorenie novej relácie...</sys:String>
    <sys:String x:Key="fw_upload_progress_prepare">Príprava nahrávania...</sys:String>
    <sys:String x:Key="fw_upload_progress_finished">Nahrávanie dokončené</sys:String>
    <sys:String x:Key="fw_upload_progress_finished_desc">Aktualizácia bola úspěšne prenesená a v súčasnej dobe se inštaluje do zariadenia. Behon tohoto procesu prestanú slúchadlá približne na 30 sekúnd reagovať. Vo väčšine prípadov sa slúchadlá pokúsia po dokončení procesu aktualizácie automaticky znovu pripojiť.</sys:String>
    <sys:String x:Key="fw_upload_progress_error">Nepodarilo sa nahrať firmware</sys:String>
    <sys:String x:Key="fw_upload_progress">Nahráva sa aktualizácia firmwaru... {0}%</sys:String>
    <sys:String x:Key="fw_upload_progress_size">({0}/{1} KB)</sys:String>
    <sys:String x:Key="fw_upload_progress_stats_mtu">Maximálna prenosová jednotka: {0} bajtov</sys:String>
    <sys:String x:Key="fw_upload_progress_stats_offset">Spracúvanie dát od offsetu 0x{0:X6} do 0x{1:X6}</sys:String>
    <sys:String x:Key="fw_upload_progress_stats_segment">Nahrávanie segmentu #{0} ({1} bajtov, kontrolný súčet 0x{2:X6})</sys:String>

    <!--Firmware parse errors-->
    <sys:String x:Key="fw_fail_no_magic">Toto nie je platná verzia firmwaru. V záhlaví súboru bola nájdená neplatná magická hodnota.</sys:String>
    <sys:String x:Key="fw_fail_size_null">Veľkosť tohto firmwaru je nastavená na nulu a nie je možné ho použiť k nahratiu. Vyberte prosím iný.</sys:String>
    <sys:String x:Key="fw_fail_no_segments">Táto verzia firmwaru neobsahuje žiadne binárne segmenty a je prázdna. Vyberte prosím inú.</sys:String>
    <sys:String x:Key="fw_fail_unknown">Neočakávaná chyba pri dekódování firmwaru. Tento archiv firmwaru môže byť poškodený.

Detaily:</sys:String>

    <!--Firmware transfer errors-->
    <sys:String x:Key="fw_fail_connection">Stratené pripojenie k zariadeniu. Prenos firmwaru bol zrušený.</sys:String>
    <sys:String x:Key="fw_fail_session">Nepodarilo sa otvoriť novú reláciu. Zariadenie vrátilo chybový kód ({0})</sys:String>
    <sys:String x:Key="fw_fail_copy">Kopírovánie firmwaru sa nepodarilo. Pripojte sa a skúste to znovu. Chybový kód vrátený zariadením: {0}</sys:String>
    <sys:String x:Key="fw_fail_verify">Overenie/inštalácia firmwaru sa nepodarila. Pripojte sa a skúste to znovu. Chybový kód vrátený zariadením: {0}</sys:String>
    <sys:String x:Key="fw_fail_connection_precheck">Zariadenie nie je aktuálne pripojené. Skontrolujte nastavenia systému Bluetooth a pripojte sa znovu.</sys:String>
    <sys:String x:Key="fw_fail_pending">Aktuálne prebieha iný prenos firmwaru. Najprv ho prosím riadne zrušte.</sys:String>
    <sys:String x:Key="fw_fail_lowbattery">Batéria je príliš slabá. Najprv prosím nabite slúchadlá nad 15%.</sys:String>
    <sys:String x:Key="fw_fail_session_timeout">Vypršal časový limit pri čakaní, než zariadenie zaháji novú reláciu</sys:String>
    <sys:String x:Key="fw_fail_control_timeout">Vypršal časový limit pri čakaní, než zariadenie vráti riadiaci blok</sys:String>

    <!--Spatial test-->
    <sys:String x:Key="spatial_header">Test priestorového senzoru</sys:String>
    <!--Note: Quaternion = 4-dimensional vector-->
    <sys:String x:Key="spatial_dump_quaternion">Surový vektor kvaterniónu:</sys:String>
    <!--Note: RPY = Roll, pitch, yaw-->
    <sys:String x:Key="spatial_dump_rpy">Hodnoty RPY:</sys:String>

    <!--Header-->
    <sys:String x:Key="window_open">Otvoriť</sys:String>
    <sys:String x:Key="window_minimize">Minimalizovať</sys:String>
    <sys:String x:Key="window_close">Zavrieť</sys:String>

    <!--Buds app detected page-->
    <sys:String x:Key="budsapp_header">Informácie o Bluetooth kompatibilite</sys:String>
    <sys:String x:Key="budsapp_text_p1">Spolu s touto aplikáciou je nainštalovaná  aj oficiálna aplikácia Galaxy Buds pre Windows 10.</sys:String>
    <sys:String x:Key="budsapp_text_p2">Pokiaľ je otvorená a pripojená, GalaxyBudsClient môže mať problémy s pripojením k Vašim slúchadlám. Než budete pokračovať, nezabudnite ju zavrieť. Taktiež sa oficiálna aplikácia Galaxy Buds nemôže pripojiť k Vašim slúchadlám ak je Galaxy Buds Manager aktívny a otvoril pripojenie k slúchadlám.</sys:String>
    <sys:String x:Key="budsapp_text_p3">Majte na pamäti, že s Vašimi slúchadlami Galaxy Buds môže komunikovať súčasne vždy len jedna aplikácia.</sys:String>

    <!--Manual pairing-->
    <sys:String x:Key="manualpair_title">Ručný výber zariadenia</sys:String>
    <sys:String x:Key="manualpair_title_dialog">Zvoľte svoje zariadenie Galaxy Buds</sys:String>
    <sys:String x:Key="manualpair_model">Zvoľte správny model</sys:String>
    <sys:String x:Key="manualpair_note">Slúchadlá by ste mali ručne pripojiť len v prípade, že ich sprievodca nastavením nerozpozná správne.</sys:String>

    <!--Rename-->
    <sys:String x:Key="rename">Premenovať slúchadlá</sys:String>
    <sys:String x:Key="rename_desc">Premenuje slúchadlá pre všetky zariadenia.</sys:String>
    <sys:String x:Key="rename_warn">Premenovanie slúchadiel nemusí byť možné pomocou oficiálnych aplikácií, pretože je obmedzené na smartphony Samsung, čo znamená, že k obnoveniu personalizovaného názvu budete možno potrebovať túto aplikáciu. Zmenu názvu nemusí zariadenie rozpoznať, pokiaľ slúchadlá neodpárujete a znovu nespárujete.</sys:String>
    <sys:String x:Key="rename_warn_oneui_title">Dôležité informácie pre užívateľov OneUI</sys:String>
    <sys:String x:Key="rename_warn_oneui">Pokiaľ je vo Vašom zariadení použité rozhranie Samsung OneUI, mali by ste použiť oficiálnu metódu spoločnosti Samsung a premenovať slúchadlá v nastaveniach systému. V opačnom prípade by pri nastavovaní nového názvu dochádzalo k problémom s pripojením.</sys:String>
    <sys:String x:Key="rename_too_short">Zadaný názov je příliš krátky (žiadne znaky) alebo príliš dlhý (maximálny limit ustanovený slúchadlami).</sys:String>
    <sys:String x:Key="rename_hint">Zadajte nový názov...</sys:String>
    <sys:String x:Key="rename_label">Nový názov zariadenia</sys:String>
    <sys:String x:Key="rename_reading_name">Čítanie aktuálneho názvu...</sys:String>
    <sys:String x:Key="rename_ok_title">Slúchadlá premenované</sys:String>
    <sys:String x:Key="rename_ok">Úspěšne ste premenovali slúchadlá!
Zmena názvu nemusí byť zariadeniami (vrátane tohto) rozpoznaná, dokiaľ slúchadlá neodpárujete a znovu     nespárujete.</sys:String>
</ResourceDictionary>
