    <!-- Usage-/metering reports -->
    <sys:String x:Key="usage_reports_header">Prehľad o používaní</sys:String>
    <sys:String x:Key="usage_reports_hint">Tieto hlásenia zhromaždujú samotné slúchadlá. Údaje sú zobrazováne tak ako sú, a môžu byť nepresné. Oficiálna aplikácia Wearable pravidelne resetuje väčšinu počítadiel a odosiela zhromaždené dáta spoločnosti Samsung, pokiaľ ste v ich aplikácii dali súhlas so zberom dát. Niektoré počítadla, napríklad nabíjacie cykly, se neresetujú.</sys:String>
    <sys:String x:Key="usage_reports_usage">Hlásenie o používaní</sys:String>
    <sys:String x:Key="usage_reports_metering">Hlásenie o metrikách</sys:String>
    <sys:String x:Key="milliamp_hours_unit">{0}mAh</sys:String>
    <sys:String x:Key="metering_total_batt_capacity">Celková kapacita batérie</sys:String>
    <sys:String x:Key="metering_a2dp_time">Doba prehrávania hudby (A2DP)</sys:String>
    <sys:String x:Key="metering_esco_time">Doba volania (eSCO)</sys:String>

    <!-- Battery history -->
    <sys:String x:Key="batt_hist_hint">Táto aplikácia môže zbierať údaje o úrovni nabitia batérie a základné údaje o používaní, čo Vám umožní analyzovať vybíjanie batérie. Dáta je možné zbierať len pokiaľ je táto aplikácia aktívna na pozadí a slúchadlá sú pripojené k tomuto zariadeniu.</sys:String>
    <sys:String x:Key="batt_hist_no_data_title">Nedostatok dát</sys:String>
    <sys:String x:Key="batt_hist_no_data">Vráťte sa prosím neskôr, až bude dostatočné množstvo dát, alebo upravte zobrazené časové rozpätie.</sys:String>
    <sys:String x:Key="batt_hist_y_axis">Nabíjanie (%)</sys:String>
    <sys:String x:Key="batt_hist_last_hour">Posledná hodina</sys:String>
    <sys:String x:Key="batt_hist_last_6_hours">Posledných 6 hodin</sys:String>
    <sys:String x:Key="batt_hist_last_12_hours">Posledných 12 hodin</sys:String>
    <sys:String x:Key="batt_hist_last_24_hours">Posledných 24 hodin</sys:String>
    <sys:String x:Key="batt_hist_last_3_days">Posledné 3 dni</sys:String>
    <sys:String x:Key="batt_hist_last_7_days">Posledných 7 dní</sys:String>
    <sys:String x:Key="batt_hist_overlay_none">Žiadne prekrytie</sys:String>
    <sys:String x:Key="batt_hist_overlay_noise_controls">Ovládánie hluku</sys:String>
    <sys:String x:Key="batt_hist_overlay_wearing">Stav nosenia</sys:String>
    <sys:String x:Key="batt_hist_overlay_host_device">Hostiteľské zariadenie</sys:String>
    <sys:String x:Key="batt_hist_overlay_legend">{0} (Prekrytie)</sys:String>
    <sys:String x:Key="batt_hist_tools_pan_and_zoom">Posun a priblíženie</sys:String>
    <sys:String x:Key="batt_hist_tools_measure_time">Doba merania</sys:String>
    <sys:String x:Key="batt_hist_tools_measure_battery">Úroveň batérie</sys:String>
    <sys:String x:Key="batt_hist_show_legend">Zobraziť nápovedu</sys:String>
    <sys:String x:Key="batt_hist_measure_difference_display">Rozdiel: {0}</sys:String>
    <sys:String x:Key="batt_hist_measure_timespan_display">Časové rozpätie: {0}</sys:String>
    <sys:String x:Key="batt_hist_measure_timespan_unit_long">d' deň(dní), 'hh'h:'mm':'ss</sys:String> <!-- This is a time span format string. It produces a string like: 2 day(s), 03h:10:01 -->
    <sys:String x:Key="batt_hist_time_span_tip_title">Časové rozpätie</sys:String>
    <sys:String x:Key="batt_hist_control_tip_title">Ovládánie myšou</sys:String>
    <sys:String x:Key="batt_hist_control_tip">Potiahnutím plátna sa môžete pohybovať po ploche.

Scrollovaním nad plátnom môžete približovať celý graf.

Scrollovaním priamo nad osou X alebo Y, môžete priblížiť len danú os. Napríklad, scrollovaním nad osou X (čas) zväčšíte/zmenšíte časové intervaly.</sys:String>
    <sys:String x:Key="batt_hist_overlay_tip_title">Prekrytie</sys:String>
    <sys:String x:Key="batt_hist_overlay_tip">Pre pridanie ďalšieho kontextu do grafu môžete použiť prekryvné vrstvy.

Ovládánie šumu: Zobrazuje, ktoré typy ANC boly zapnuté alebo vypnuté.

Stav nosenia: Zobrazuje, či boli slúchadlá nasadené, alebo nie.

Hostiteľské zariadenie: Zobrazuje, ktoré slúchadlo bolo hostiteľom Bluetooth pripojenia k počítaču.

Prekryvné údaje môžu byť pri zobrazení veľkých časových rozsahov tažko čitateľné. Scrollovaním priamo nad osou X môžete priblížiť konkrétny časový rozsah pre lepší prehľad.</sys:String>
    <sys:String x:Key="batt_hist_tools_tip_title">Nástroje</sys:String>
    <sys:String x:Key="batt_hist_tools_tip">Posun a priblíženie: Predvolený režim. Pohybujte se po ploche posúvaním a přibližovaním.

Doba merania: Výberom horizontálneho rozpätia odmeráte uplynulý čas medzi začiatkom a koncomm výberu.

Úroveň batérie: Výberom vertikálneho rozpätia odmeráte rozdiel úrovne nabitia batérie medzi začiatkem a koncom výberu.</sys:String>

    <!--Settings-->
    <sys:String x:Key="settings_header">Nastavenia</sys:String>
    <sys:String x:Key="settings_save_fail_no_access">Nepodarilo sa uložiť nastavenia. Prístup k konfiguračnému súboru bol zamietnutý operačným systémom. Skontrolujte prosím oprávnenia súboru {0}.</sys:String>
    <sys:String x:Key="settings_appearance">Vzhľad</sys:String>
    <sys:String x:Key="settings_darkmode">Tmavý režim</sys:String>
    <sys:String x:Key="settings_darkmode_description">Použije tmavšie farebné schéma</sys:String>
    <sys:String x:Key="settings_blurstrength">Úroveň rozmazania okna</sys:String>
    <sys:String x:Key="settings_blurstrength_description">Kompatibilné len s tmavým režimom. Nie je podporované na všetkých systémoch</sys:String>
    <sys:String x:Key="settings_accent">Farba akcentu</sys:String>
    <sys:String x:Key="settings_accent_description">Výber vlastnej farvy akcentu</sys:String>
    <sys:String x:Key="settings_transitions">Prechod</sys:String>
    <sys:String x:Key="settings_transitions_description">Povoliť prechod medzi snímkami</sys:String>
    <sys:String x:Key="settings_localization_disable">Jazyk</sys:String>
    <sys:String x:Key="settings_localization_description">Zmena jazyka aplikácie</sys:String>
    <sys:String x:Key="settings_minimize_tray">Minimalizovať do lišty</sys:String>
    <sys:String x:Key="settings_minimize_tray_description">Ponechá aplikáciu na pozadí miesto ukončenia aplikácie</sys:String>
    <sys:String x:Key="settings_realistic_earbud_icons">Používať realistické obrázky slúchadiel</sys:String>
    <sys:String x:Key="settings_realistic_earbud_icons_description">Zobrazí realistické a farebné obrázky slúchadiel, pokiaľ to podporujú</sys:String>
    <sys:String x:Key="settings_color_override">Prepísať farbu slúchadiel</sys:String>
    <sys:String x:Key="settings_color_override_description">Zmení zobrazenú farbu slúchadiel v aplikácii</sys:String>
    <sys:String x:Key="settings_nav_sidebar">Bočný panel navigácie</sys:String>
    <sys:String x:Key="settings_nav_sidebar_description">Zobrazí alebo skryje navigačné tlačidlá na ľavej strane</sys:String>
    <sys:String x:Key="settings_tray_settings">Ikona lišty & Spustenie</sys:String>
    <sys:String x:Key="settings_dyn_tray_mode">Dynamická ikona v oznamovacej oblasti</sys:String>
    <sys:String x:Key="settings_dyn_tray_mode_description">Zobrazí stavu batérie na ikone v oznamovacej oblasti</sys:String>
    <sys:String x:Key="settings_dyn_tray_mode_off">Vypnuté</sys:String>
    <sys:String x:Key="settings_dyn_tray_mode_battery_min">Zobraziť najnižšiu úroveň nabitia batérie</sys:String>
    <sys:String x:Key="settings_dyn_tray_mode_battery_avg">Zobraziť priemernú úroveň nabitia batérie</sys:String>
    <sys:String x:Key="settings_autostart">Spustiť pri štarte systému</sys:String>
    <sys:String x:Key="settings_autostart_description">Spustiť minimalizované pri štarte systému</sys:String>
    <sys:String x:Key="settings_autostart_permission">Nepodarilo sa nastaviť položku automatického spustenia v registri. Prístup do registru (HKCU) bol zakázaný správcom systému</sys:String>
    <sys:String x:Key="settings_connpopup">Vyskakovacie okno pripojenia</sys:String>
    <sys:String x:Key="settings_devmode">Vývojárske možnosti</sys:String>
    <sys:String x:Key="settings_devmode_description">Nahliadhnutie na Bluetooth prevádzku a ďalšie vývojárske nástroje</sys:String>
    <sys:String x:Key="settings_crowdsourcing">Crowdsourcing</sys:String>

    <!--Settings >>> Connection popup-->
    <sys:String x:Key="settings_cpopup_header">Vyskakovacie okno pripojenia</sys:String>
    <sys:String x:Key="settings_cpopup_enable">Povoliť vyskakovacie okno pripojenia</sys:String>
    <sys:String x:Key="settings_cpopup_enable_description">Zobrazí informácie o stave batérie pri pripojení slúchadiel.</sys:String>
    <sys:String x:Key="settings_cpopup_compact">Kompaktný režim</sys:String>
    <sys:String x:Key="settings_cpopup_compact_description">Schová hlavičku vyskakovacieho okna pre ušetrenie miesta</sys:String>
    <sys:String x:Key="settings_cpopup_position">Umiestnenie</sys:String>
    <sys:String x:Key="settings_cpopup_position_description">Vyberte kde sa má okno zobraziť</sys:String>
    <sys:String x:Key="settings_cpopup_demo">Zobraziť náhľad vyskakovacieho okna</sys:String>

    <!--Settings >>> Crowdsourcing settings-->
    <sys:String x:Key="settings_crowd_header">Crowdsourcing</sys:String>
    <sys:String x:Key="settings_crowd_allow">Povoliť prispievanie do crowdsourcingu</sys:String>
    <sys:String x:Key="settings_crowd_allow_description">Zbiera informácie o proprietarnéj štruktúre protokolu Bluetooth spoločnosti Samsung a dáta na vyžiadanie. Umožňuje nám to omnoho jednoduchšie podporovať všetky dostupné modely Galaxy Buds, bez potreby ich vlastniť.</sys:String>
    <sys:String x:Key="settings_crowd_crashreport">Povoliť správy o zlyhaniach aplikácie</sys:String>
    <sys:String x:Key="settings_crowd_crashreport_description">Automaticky odosiela správy o zlyhaniach aplikácie pomocou Sentry. Pomáha nám to rýchlejšie reagovať na problematické a rušivé chyby v aplikácii.</sys:String>

    <!--Factory reset-->
    <sys:String x:Key="factory_header">Obnova továrnych nastavení</sys:String>
    <sys:String x:Key="factory_confirmation">Ste si istý, že chcete obnoviť továrne nastavenia slúchadiel?
Toto odstráni všetky dáta a nastavenia zo slúchadiel.

Pred pokračovaním sa uistite, že sú obe slúchadlá zapnuté.</sys:String>
    <sys:String x:Key="factory_error_title">Obnovenie továrnych nastavení sa nepodarilo</sys:String>
    <sys:String x:Key="factory_error">Zariadenia vrátilo kód chyby: {0}

Skontrolujte, či sú obe slúchadlá zapnuté a dosiahnuteľné.
Je možné, že ich bude nutné znova manuálne pripojiť.</sys:String>

    <!--Find my Gear-->
    <sys:String x:Key="fmg_warning_both">Vyberte si prosím obe slúchadlá z uší.</sys:String>
    <sys:String x:Key="fmg_warning_left">Vyberte si prosím ľavé slúchadlo z ucha.</sys:String>
    <sys:String x:Key="fmg_warning_right">Vyberte si prosím pravé slúchadlo z ucha.</sys:String>
