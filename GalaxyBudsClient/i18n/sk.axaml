    <sys:String x:Key="fmg_smart_things_find_manage">Spravovať dáta SmartThings Find</sys:String>
    <sys:String x:Key="fmg_smart_things_find_manage_desc">Zobraziť a spravovať dáta SmartThings Find uložené v slúchadlách</sys:String>
    <sys:String x:Key="fmg_smart_things_find_open">Otvoriť webovú stránku SmartThings Find</sys:String>
    <sys:String x:Key="fmg_smart_things_find_open_desc">Sledujte svoje slúchadlá online. K nastaveniu je potrebné mať účet Samsung a oficiálnu aplikáciu SmartThings Find.</sys:String>

    <!--SmartThings data-->
    <sys:String x:Key="smart_things_find">SmartThings</sys:String>
    <sys:String x:Key="smart_things_find_clear">Odstrániť konfiguráciu SmartThings Find</sys:String>
    <sys:String x:Key="smart_things_find_clear_desc">Odstráni dáta súvisiace s úČtom Samsung zo slúchadiel</sys:String>
    <sys:String x:Key="smart_things_find_iv">Inicializačný vektor (IV)</sys:String>
    <sys:String x:Key="smart_things_find_secret_key">Tajný kľúč</sys:String>
    <sys:String x:Key="smart_things_find_region">Oblasť</sys:String>
    <sys:String x:Key="smart_things_find_fmm_token">SmartThings Find token</sys:String>
    <sys:String x:Key="smart_things_find_no_link">Vaše slúchadlá nie sú pripojené k sieti Samsung SmartThings Find.</sys:String>
    <sys:String x:Key="smart_things_find_write_fail">Slúchadla odmietli nové konfiguračné dáta SmartThings Find.</sys:String>
