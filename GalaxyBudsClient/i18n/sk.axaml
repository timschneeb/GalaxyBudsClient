    <!--Device selection page (setup)-->
    <sys:String x:Key="devsel_header">Vyberte svoje Galaxy Buds</sys:String>
    <sys:String x:Key="devsel_manual_pair_title">Chýba Vaše zariadenie v zozname?</sys:String>
    <sys:String x:Key="devsel_manual_pair_description">Uistite sa, že vaše slúchadlá už boli spárované. Pokiaľ stále nie sú rozpoznané, skúste použiť možnosť ručného pripojenia.</sys:String>
    <sys:String x:Key="devsel_manual_pair">Ručné pripojenie</sys:String>
    <sys:String x:Key="devsel_nodevices">Prosím, najprv pripojte a spárujte Vaše slúchadlá.</sys:String>
    <sys:String x:Key="devsel_nodevices_title">Nenájdené žiadne spárované zariadenie</sys:String>
    <sys:String x:Key="devsel_invalid_selection">Prosím vyberte správné zariadenie</sys:String>
    <sys:String x:Key="devsel_winrt_title">Použiť alternativné rozhranie Bluetooth</sys:String>
    <sys:String x:Key="devsel_winrt">Omnoho lepšia stabilita, ale nemusí fungovať na všetkých počítačoch s niektorými Bluetooth adaptérmi</sys:String>

