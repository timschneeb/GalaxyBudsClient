    <sys:String x:Key="nc_one_earbud">Potlačenie hluku jedným slúchadlom</sys:String>
    <sys:String x:Key="nc_one_earbud_description">Pre potlačenie hluku sú obvykle potrebné obe slúchadlá, aby nedochádzalo k nepohodliu, povoľte túto funkciu, aby bolo možné potlačiť hluk len jedným slúchadlom</sys:String>
    <sys:String x:Key="nc_anc_level">Vysoká citlivosť</sys:String>
    <sys:String x:Key="nc_anc_level_description">Silnější účinok potlačenia hluku</sys:String>
    <sys:String x:Key="nc_ambient">Prispôsobenie okolného zvuku</sys:String>
    <sys:String x:Key="nc_ambient_description">Nakonfiguruje tón a hlasitosť okolného zvuku (ak je k dispozíci)</sys:String>
    <sys:String x:Key="nc_voicedetect">Detekcia rozhovoru</sys:String>
    <sys:String x:Key="nc_voicedetect_description">Pokiaľ je rozpoznaný Váš hlas, automaticky zapne okolité zvuky a zníží hlasitosť médií pre uľahčenie konverzácie</sys:String>
    <sys:String x:Key="nc_voicedetect_timeout">Časový limit konverzácie</sys:String>
    <sys:String x:Key="nc_voicedetect_timeout_description">Vráti nastavenia, pokiaľ Váš hlas nie je po určitú dobu detekovaný</sys:String>
