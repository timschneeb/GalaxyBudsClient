    <!--Advanced page-->
    <sys:String x:Key="adv_header">Pokročilé nastavenia</sys:String>
    <sys:String x:Key="adv_seamless">Jednoduché pripájanie slúchadiel</sys:String>
    <sys:String x:Key="adv_seamless_desc">Umožňuje rýchlo pripojiť slúchadlá k ďalšiemu zariadeniu bez nutnosti ich odpojovať alebo zapínat režim párovania</sys:String>
    <sys:String x:Key="adv_pause_playback">Prerušiť skladbu pri zosadení slúchadiel</sys:String>
    <sys:String x:Key="adv_pause_playback_desc">Pošle globálnu akciu pre prehrávanie/pozastavenie pokiaľ obe senzory priblíženia sú odkryté (len Desktop)</sys:String>
    <sys:String x:Key="adv_resume_playback">Začať prehrávať keď sú slúchadlá v uchu</sys:String>
    <sys:String x:Key="adv_resume_playback_desc">Pošle globálnu akciu pre prehrávanie/pozastavenie pokiaľ je aspoň jeden senzor priblíženia zakrytý (len Desktop)</sys:String>
    <sys:String x:Key="adv_sidetone">Použiť ambientný režim pri hovoroch</sys:String>
    <sys:String x:Key="adv_sidetone_desc">Svoj hlas budete počuť jasnejšie pri telefonovaní (obmedzí zbytočné kričanie)</sys:String>
    <sys:String x:Key="adv_callpath">Detekcia volania v ušiach</sys:String>
    <sys:String x:Key="adv_callpath_desc">Prehráva hovory cez slúchadlá, ak ich máte v ušiach, a cez reproduktor počítača, ak nie</sys:String>
    <sys:String x:Key="adv_passthrough">Zmierňiť tlak pri zapnutí ambientního režimu</sys:String>
    <sys:String x:Key="adv_passthrough_desc">Zmierňuje pocit dusnosti, ak nie je používané aktivné potlačenie hluku</sys:String>
    <sys:String x:Key="adv_extra_clear_call">Zaostriť zvuk volania</sys:String>
    <sys:String x:Key="adv_extra_clear_call_desc">Zvýši zretelnosť hovoru. Najužitočnejšie, ak ste na hlučnom mieste a používate slúchadlá. Spotrebúva viac batérie.</sys:String>
    <sys:String x:Key="adv_hotkey">Klávesové skratky</sys:String>
    <sys:String x:Key="adv_hotkey_desc">Definovať vlastné klávesové skratky pre ďialkové ovládanie slúchadiel</sys:String>
    <sys:String x:Key="adv_bixby_remap">Premapovať prebudenie Bixby</sys:String>
    <sys:String x:Key="adv_bixby_remap_desc">Definujte, čo sa stane, ak poviete 'Hey Bixby!'</sys:String>

    <!--Remap bixby wakeup-->
    <sys:String x:Key="bixby_remap_enable">Povoliť prebudenie Bixby</sys:String>
    <sys:String x:Key="bixby_remap_enable_desc">Spustí Bixby na Vašom telefóne Samsung alebo spustí vlastnú akciu na tomto počítači pri prebudení.</sys:String>
    <sys:String x:Key="bixby_remap_lang">Jazyk prebudenia Bixby</sys:String>
    <sys:String x:Key="bixby_remap_lang_desc">Zmeňte jazyk použitý pre aktivačnú frázu</sys:String>
    <sys:String x:Key="bixby_remap_action">Vlastná akcia prebudenia</sys:String>
    <sys:String x:Key="bixby_remap_action_desc">Definujte, čo sa má stať, ak aktivujete Bixby na tomto zariadení</sys:String>
    <sys:String x:Key="bixby_remap_note">Povedzte 'Hey Bixby!' pre aktiváciue. Aktivovacia fráza sa môže líšiť v iných jazykových nastaveniach.

Konfigurácia premapovania je aktivna len na tomto zariadení. Pokiaľ pripojíte slúchadlá k zariadení Samsung, hlasové prebudenie normálne aktivuje Bixby. Na iných zariadeniach, ako je toto, a na telefónoch iných výrobcov, táto funkcia nespustí žiadnú akciu.</sys:String>


