    <sys:String x:Key="coredump_header">Zhromažďovanie dát...</sys:String>
    <sys:String x:Key="coredump_dl_progress_prepare">Príprava sťahovanie...</sys:String>
    <sys:String x:Key="coredump_dl_progress_finished">Sťahovanie dokončené</sys:String>
    <sys:String x:Key="coredump_dl_trace_progress">Sťahovanie záznamu trasovania... {0}%</sys:String>
    <sys:String x:Key="coredump_dl_core_progress">Sťahovanie výpisu jadra... {0}%</sys:String>
    <sys:String x:Key="coredump_dl_progress_size">({0}/{1} bytov)</sys:String>
    <sys:String x:Key="coredump_dl_note">Počas sťahovania je zvukový stream dočasne pozastavený. Vaše slúchadlá sa odpoja, akonáhle prenos skončí, prosím, pripojte ich manuálne naspäť.
Po dokončení budete vyzvaný k výberu adresára pre všetky zhromaždené údaje.

Pokiaľ sa prenos zasekne alebo sa zariadenie dočasne odpojilo, musíte reštartovať sťahovanie. Táto funkcia je v súčasnej dobe veľmi nestabilná.</sys:String>
    <sys:String x:Key="coredump_dl_save_fail_title">Uloženie záznamu zlyhalo</sys:String>
    <sys:String x:Key="coredump_dl_save_fail">Problém pri kopírovaní záznamu z dočasného umiestnenia. Dôvod: {0}</sys:String>
    <sys:String x:Key="coredump_dl_save_success_title">Záznamy boli úspešne uložené</sys:String>
    <sys:String x:Key="coredump_dl_save_success">{0} záznam(y) boli zapísané do '{1}'</sys:String>
    <sys:String x:Key="coredump_dl_save_dialog_title">Zvoľte adresár pre stiahnutie ...</sys:String>

    <!-- Hidden AT modes -->
    <sys:String x:Key="hidden_mode_warning">Postupujte s rozvahou</sys:String>
    <sys:String x:Key="hidden_mode_warning_desc">Niektoré zmeny uskutočnené na tejto stránke sa nedajú obnoviť továrenskými nastaveniami. Nie všetky modely tieto nastavenia podporujú.</sys:String>
    <sys:String x:Key="hidden_mode_target">Cieľové zariadenie: {0} slúchadlo</sys:String> <!-- {0} = Left or Right -->
    <sys:String x:Key="hidden_mode_target_l_desc">Pokiaľ chcete upravovať ľavé slúchadlo, vložte pravé slúchadlo do púzdra a zavrite ho.</sys:String>
    <sys:String x:Key="hidden_mode_target_r_desc">Pokiaľ chcete upravovať pravé slúchadlo, vložte ľavé do púzdra a zavrite ho.</sys:String>
    <sys:String x:Key="hidden_mode_input_wrong_length">Nová hodnota musí mať presne {0} znakov.</sys:String>
    <sys:String x:Key="hidden_mode_uart_on_confirm">UART bol úspěšne zapnutý</sys:String>
    <sys:String x:Key="hidden_mode_uart_off_confirm">UART bol úspěšne vypnutý</sys:String>
    <sys:String x:Key="hidden_mode_uart">Zapnúť UART port</sys:String>
    <sys:String x:Key="hidden_mode_uart_desc">Dočasne povolí fyzický UART port na doske plošných spojov aktuálneho cieľového zariadenia pre účely ladenia.</sys:String>
