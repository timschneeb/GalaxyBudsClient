    <!--Connection lost page-->
    <sys:String x:Key="connlost">Connessione persa</sys:String>
    <sys:String x:Key="connlost_header">Impossibile stabilire una connessione</sys:String>
    <sys:String x:Key="connlost_connect">Connetti</sys:String>
    <sys:String x:Key="connlost_connecting">Connessione in corso...</sys:String>
    <sys:String x:Key="connlost_troubleshoot">Risoluzione problemi</sys:String>
    <sys:String x:Key="connlost_troubleshoot_title">Come risolvere i problemi di connessione</sys:String>
    <sys:String x:Key="connlost_troubleshoot_content">Assicurati che l'app ufficiale Samsung Wearable per i Galaxy Buds non stia tentando di connettersi ai tuoi auricolari in background.
Altrimenti, riscontrerai frequentissimi problemi di perdita di connessione poiché la loro app cercherà ripetutamente di assumere il controllo sugli auricolari.

Puoi scegliere una di queste soluzioni per risolvere il problema:

• Disaccoppia gli auricolari dall'app Wearable. (Nell'app Wearable, apri il menu ad hamburger, seleziona 'Gestisci dispositivi' ed elimina gli auricolari dall'elenco).

• Disinstalla del tutto il plugin Galaxy Buds per l'app Samsung Wearable.

• Usa un'app come 'Hail' o 'Ice Box' per congelare temporaneamente il plugin ufficiale Galaxy Buds, così da impedirne l'esecuzione in background.
    </sys:String>

    <!-- Pairing mode -->
    <sys:String x:Key="connlost_disconnected">Dispositivo disconnesso</sys:String>
    <sys:String x:Key="pairingmode_done">Gli auricolari sono entrati in modalità di associazione e ora sono disconnessi da questo dispositivo.</sys:String>

    <!--Firmware update disclaimer-->
    <sys:String x:Key="fw_disclaimer">Avvertenza</sys:String>
    <sys:String x:Key="fw_disclaimer_desc">Questo strumento di aggiornamento del firmware è un'accurata replica di quello ufficiale presente nell'app Android di Samsung. Ho testato minuziosamente questa implementazione in varie circostanze (funzionamento normale, perdita di connessione, pacchetti Bluetooth intenzionalmente corrotti, ecc.) senza mai riscontrare alcun problema. Tuttavia, non mi assumo alcuna responsabilità per eventuali malfunzionamenti, dal momento che gli aggiornamenti software modificano componenti di sistema vitali e dovrebbero essere sempre maneggiati con attenzione.
    
DOWNGRADE: Sebbene sia possibile effettuare il downgrade a versioni precedenti del firmware (e finora non ho mai riscontrato problemi nel farlo), ciò potrebbe causare malfunzionamenti inaspettati e andrebbe fatto solo se strettamente necessario. Un ripristino ai dati di fabbrica dopo il downgrade è raccomandato ma di solito non essenziale.

FLASH PERSONALIZZATO: È possibile anche caricare file firmware direttamente dal tuo hard disk. NON flashare sul tuo dispositivo binari firmware progettati per ALTRI modelli.  
    
Questa applicazione è distribuita con licenza GPLv3. Utilizzandola, accetti la licenza e le sue limitazioni di responsabilità. Premi 'Continua' per accettare.</sys:String>

    <!--Firmware selection-->
    <sys:String x:Key="fw_select_header">Aggiornamenti firmware</sys:String>
    <sys:String x:Key="fw_select_downgrade">Permetti downgrade del firmware</sys:String>
    <sys:String x:Key="fw_select_downgrade_desc">Disabilita il controllo della versione e mostra i firmware più vecchi nell'elenco (potrebbe causare problemi inaspettati; solo per utenti esperti)</sys:String>
    <sys:String x:Key="fw_select_install">Installa firmware</sys:String>
    <sys:String x:Key="fw_select_install_short">Installa</sys:String>
    <sys:String x:Key="fw_select_from_disk">Seleziona firmware dal disco...</sys:String>
    <sys:String x:Key="fw_select_from_disk_short">Apri</sys:String>
    <sys:String x:Key="fw_select_refresh">Aggiorna</sys:String>
    <sys:String x:Key="fw_select_unsupported_selection">Selezione non valida. Seleziona un elemento compatibile dall'elenco.</sys:String>
    <sys:String x:Key="fw_select_downloading">Scaricamento in corso...</sys:String>
    <sys:String x:Key="fw_select_net_error">Comunicazione con il server fallita. Impossibile scaricare il firmware al momento.</sys:String>
    <sys:String x:Key="fw_select_net_index_error">Comunicazione con il server fallita. Impossibile scaricare l'indice del firmware al momento.</sys:String>
    <sys:String x:Key="fw_select_http_error">Codice di errore HTTP:</sys:String>
    <sys:String x:Key="fw_select_unknown_build">Nome build sconosciuto</sys:String>
    <sys:String x:Key="fw_select_no_results_short">Nessun aggiornamento trovato</sys:String>
    <sys:String x:Key="fw_select_verify_fail">Verifica del firmware fallita</sys:String>
    <sys:String x:Key="fw_select_verify_model_mismatch_fail">Rilevata una mancata corrispondenza del modello! Il trasferimento del firmware è stato annullato.
    
Stai tentando di flashare un firmware per il {0} sul tuo {1}. Ciò potrebbe rendere permanentemente inutilizzabili (brick) i tuoi auricolari.</sys:String>
    <sys:String x:Key="fw_select_confirm">Stai per flashare '{0}' sul tuo dispositivo '{1}'</sys:String>
    <sys:String x:Key="fw_select_confirm_desc">Assicurati che queste informazioni siano corrette, altrimenti premi 'Annulla' e ricontrolla. 

Se possibile, controlla che entrambi gli auricolari siano connessi prima di iniziare. Non ci saranno problemi se la connessione dovesse fallire durante il trasferimento dell'aggiornamento. In tal caso, gli auricolari annulleranno automaticamente il processo di trasferimento e usciranno dalla modalità di aggiornamento firmware. 

Premi 'Continua' per avviare l'aggiornamento.</sys:String>

    <!--Firmware transfer-->
    <sys:String x:Key="fw_upload_header">Installazione del firmware...</sys:String>
    <sys:String x:Key="fw_upload_progress_session">Creazione di una nuova sessione...</sys:String>
    <sys:String x:Key="fw_upload_progress_prepare">Preparazione al caricamento...</sys:String>
    <sys:String x:Key="fw_upload_progress_finished">Caricamento completato</sys:String>
    <sys:String x:Key="fw_upload_progress_finished_desc">L'aggiornamento è stato trasferito con successo ed è attualmente in fase di installazione sul dispositivo. Durante questo processo, i tuoi auricolari non risponderanno per circa 30 secondi. Nella maggior parte dei casi, gli auricolari cercheranno di ricollegarsi automaticamente al termine del processo di aggiornamento integrato.</sys:String>
    <sys:String x:Key="fw_upload_progress_error">Caricamento del firmware fallito</sys:String>
    <sys:String x:Key="fw_upload_progress">Caricamento aggiornamento firmware in corso... {0}%</sys:String>
    <sys:String x:Key="fw_upload_progress_size">({0}/{1} KB)</sys:String>
    <sys:String x:Key="fw_upload_progress_stats_mtu">Maximum transfer unit (MTU): {0} byte</sys:String>
    <sys:String x:Key="fw_upload_progress_stats_offset">Elaborazione dei dati dall'offset 0x{0:X6} al 0x{1:X6}</sys:String>
    <sys:String x:Key="fw_upload_progress_stats_segment">Caricamento segmento #{0} ({1} byte, checksum 0x{2:X6})</sys:String>

    <!--Firmware parse errors-->
    <sys:String x:Key="fw_fail_no_magic">Questo non è un binario del firmware valido. Trovato valore magico non valido nell'intestazione del file.</sys:String>
    <sys:String x:Key="fw_fail_size_null">Questo binario del firmware ha una dimensione pari a zero e non può essere usato per il flash. Scegline un altro.</sys:String>
    <sys:String x:Key="fw_fail_no_segments">Questo binario del firmware non contiene segmenti binari ed è vuoto. Scegline un altro.</sys:String>
    <sys:String x:Key="fw_fail_unknown">Errore imprevisto durante la decodifica del binario del firmware. L'archivio potrebbe essere corrotto.  

Dettagli:</sys:String>

    <!--Firmware transfer errors-->
    <sys:String x:Key="fw_fail_connection">Connessione al dispositivo persa. Il trasferimento del firmware è stato annullato.</sys:String>
    <sys:String x:Key="fw_fail_session">Apertura di una nuova sessione fallita. Il dispositivo ha restituito il codice errore ({0})</sys:String>
    <sys:String x:Key="fw_fail_copy">Copia del binario del firmware fallita. Riconnetti e riprova. Codice di errore restituito dal dispositivo: {0}</sys:String>
    <sys:String x:Key="fw_fail_verify">Verifica/installazione del binario del firmware fallita. Riconnetti e riprova. Codice di errore restituito dal dispositivo: {0}</sys:String>
    <sys:String x:Key="fw_fail_connection_precheck">Il dispositivo non è attualmente connesso. Controlla le impostazioni Bluetooth del tuo sistema e riconnetti.</sys:String>
    <sys:String x:Key="fw_fail_pending">Un altro trasferimento di firmware è già in corso. Annullalo correttamente prima di procedere.</sys:String>
    <sys:String x:Key="fw_fail_lowbattery">Batteria troppo bassa. Ricarica gli auricolari oltre il 15% prima di riprovare.</sys:String>
    <sys:String x:Key="fw_fail_session_timeout">Tempo scaduto in attesa che il dispositivo apra una nuova sessione</sys:String>
    <sys:String x:Key="fw_fail_control_timeout">Tempo scaduto in attesa che il dispositivo restituisca un blocco di controllo</sys:String>

    <!--Spatial test-->
    <sys:String x:Key="spatial_header">Sensore spaziale</sys:String>
    <!--Note: Quaternion = 4-dimensional vector-->
    <sys:String x:Key="spatial_dump_quaternion">Vettore quaternione grezzo:</sys:String>
    <!--Note: RPY = Roll, pitch, yaw-->
    <sys:String x:Key="spatial_dump_rpy">Valori RPY:</sys:String>

    <!--Header-->
    <sys:String x:Key="window_open">Apri</sys:String>
    <sys:String x:Key="window_minimize">Riduci a icona</sys:String>
    <sys:String x:Key="window_close">Chiudi</sys:String>

    <!--Buds app detected page-->
    <sys:String x:Key="budsapp_header">Informazioni compatibilità Bluetooth</sys:String>
    <sys:String x:Key="budsapp_text_p1">L'app ufficiale Galaxy Buds è installata accanto a questa applicazione.</sys:String>
    <sys:String x:Key="budsapp_text_p2">Se è attiva in background, GalaxyBudsClient potrebbe avere problemi a connettersi ai tuoi auricolari. Assicurati di disaccoppiare gli auricolari dall'app ufficiale o di impedirle di funzionare in background in altri modi.</sys:String>
    <sys:String x:Key="budsapp_text_p3">Tieni a mente che solo un'applicazione alla volta può comunicare con i tuoi Galaxy Buds.</sys:String>

    <!--Manual pairing-->
    <sys:String x:Key="manualpair_title">Selezione manuale del dispositivo</sys:String>
    <sys:String x:Key="manualpair_title_dialog">Scegli il tuo dispositivo Galaxy Buds</sys:String>
    <sys:String x:Key="manualpair_model">Scegli il tipo di modello corretto</sys:String>
    <sys:String x:Key="manualpair_note">Dovresti connettere manualmente i tuoi auricolari solo se la configurazione guidata non li riconosce correttamente.</sys:String>

    <!--Rename-->
    <sys:String x:Key="rename">Rinomina auricolari</sys:String>
    <sys:String x:Key="rename_desc">Questo rinominerà gli auricolari per tutti i dispositivi.</sys:String>
    <sys:String x:Key="rename_warn">Rinominare gli auricolari potrebbe non essere possibile usando le app ufficiali poiché Samsung limita la funzione ai propri smartphone; ciò significa che potresti aver bisogno di questa app per reimpostare il nome personalizzato. Il cambio di nome potrebbe non essere rilevato dai dispositivi finché non disaccoppi e riaccoppi i tuoi auricolari.</sys:String>
    <sys:String x:Key="rename_warn_oneui_title">Informazioni importanti per gli utenti OneUI</sys:String>
    <sys:String x:Key="rename_warn_oneui">Se il tuo dispositivo esegue Samsung OneUI, dovresti usare il metodo ufficiale Samsung per rinominare i tuoi auricolari nelle impostazioni di sistema. In caso contrario, ci saranno problemi di connessione durante l'impostazione di un nuovo nome.</sys:String>
    <sys:String x:Key="rename_too_short">Il nome che hai inserito è troppo corto (nessun carattere) o troppo lungo (limite massimo imposto dagli auricolari).</sys:String>
    <sys:String x:Key="rename_hint">Inserisci nuovo nome...</sys:String>
    <sys:String x:Key="rename_label">Nuovo nome del dispositivo</sys:String>
    <sys:String x:Key="rename_reading_name">Lettura del nome attuale...</sys:String>
    <sys:String x:Key="rename_ok_title">Auricolari rinominati</sys:String>
    <sys:String x:Key="rename_ok">I tuoi auricolari sono stati rinominati con successo! 
Il cambio di nome potrebbe non essere rilevato dai dispositivi (incluso questo) finché non disaccoppi e riaccoppi i tuoi auricolari.</sys:String>
</ResourceDictionary>
