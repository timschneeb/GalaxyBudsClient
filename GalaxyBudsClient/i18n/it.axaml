    <sys:String x:Key="at_terminal_cmd_id">ID comando</sys:String>
    <sys:String x:Key="at_terminal_cmd_param">Parametro del comando (opzionale)</sys:String>
    <sys:String x:Key="at_terminal_cmd_id_invalid">Questo ID comando non è valido. Inserisci un valore esadecimale a 16 bit, ad esempio 0007 o 004C.</sys:String>
