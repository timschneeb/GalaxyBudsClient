    <sys:String x:Key="adv_pause_playback">Metti in pausa la riproduzione se gli auricolari non sono indossati</sys:String>
    <sys:String x:Key="adv_pause_playback_desc">Invia un evento globale di riproduzione/pausa quando entrambi i sensori di prossimità sono scoperti (solo Desktop)</sys:String>
    <sys:String x:Key="adv_resume_playback">Riprendi la riproduzione se gli auricolari vengono indossati</sys:String>
    <sys:String x:Key="adv_resume_playback_desc">Invia un evento globale di riproduzione/pausa quando almeno uno dei sensori di prossimità è coperto (solo Desktop)</sys:String>
    <sys:String x:Key="adv_sidetone">Usa il suono ambientale durante le chiamate</sys:String>
    <sys:String x:Key="adv_sidetone_desc">Senti la tua voce più chiaramente quando sei al telefono</sys:String>
    <sys:String x:Key="adv_callpath">Rilevamento auricolari per le chiamate</sys:String>
    <sys:String x:Key="adv_callpath_desc">Riproduci le chiamate tramite gli auricolari quando sono nelle tue orecchie e tramite l'altoparlante del computer quando non lo sono</sys:String>
    <sys:String x:Key="adv_extra_clear_call">Rendi più nitido l'audio in chiamata</sys:String>
    <sys:String x:Key="adv_extra_clear_call_desc">Aumenta la chiarezza delle chiamate. Molto utile quando ti trovi in un ambiente rumoroso e usi gli auricolari. Consuma più batteria.</sys:String>
    <sys:String x:Key="adv_passthrough">Allevia la pressione con il suono ambientale</sys:String>
    <sys:String x:Key="adv_passthrough_desc">Questo può prevenire una sensazione di ovattamento o compressione quando non stai usando la cancellazione attiva del rumore</sys:String>
    <sys:String x:Key="adv_hotkey">Scorciatoie da tastiera</sys:String>
    <sys:String x:Key="adv_hotkey_desc">Definisci scorciatoie da tastiera personalizzate per controllare a distanza i tuoi auricolari</sys:String>
    <sys:String x:Key="adv_bixby_remap">Rimappa attivazione di Bixby</sys:String>
    <sys:String x:Key="adv_bixby_remap_desc">Definisci cosa deve accadere quando dici 'Hey Bixby!'</sys:String>

    <!--Remap bixby wakeup-->
    <sys:String x:Key="bixby_remap_enable">Abilita attivazione di Bixby</sys:String>
    <sys:String x:Key="bixby_remap_enable_desc">Lancia Bixby sul tuo telefono Samsung o esegui un'azione personalizzata su questo PC al momento dell'attivazione vocale</sys:String>
    <sys:String x:Key="bixby_remap_lang">Lingua di attivazione di Bixby</sys:String>
    <sys:String x:Key="bixby_remap_lang_desc">Cambia la lingua utilizzata per la frase di attivazione</sys:String>
    <sys:String x:Key="bixby_remap_action">Azione di attivazione personalizzata</sys:String>
    <sys:String x:Key="bixby_remap_action_desc">Definisci cosa deve succedere quando attivi Bixby su questo dispositivo</sys:String>
    <sys:String x:Key="bixby_remap_note">Dì 'Hey Bixby!' per attivarlo. La frase di attivazione potrebbe essere diversa a seconda delle impostazioni della lingua.

La rimappatura è attiva solo su questo dispositivo. Se connetti i tuoi auricolari a un dispositivo Samsung, l'attivazione vocale aprirà Bixby normalmente. Su dispositivi diversi da questo o su telefoni non Samsung, questa funzione non scatenerà alcuna azione.</sys:String>


    <!--Credits-->
    <sys:String x:Key="credits_header">Riconoscimenti</sys:String>
    <sys:String x:Key="credits_developer">Sviluppatore</sys:String>
