    <sys:String x:Key="hidden_mode_uart">Abilita porta UART</sys:String>
    <sys:String x:Key="hidden_mode_uart_desc">Abilita temporaneamente la porta fisica UART sul PCB del dispositivo di destinazione a scopo di debug</sys:String>
    <sys:String x:Key="hidden_mode_power">Menu di alimentazione</sys:String>
    <sys:String x:Key="hidden_mode_power_desc">Spegni, riavvia o metti in standby il dispositivo di destinazione corrente</sys:String>
    <sys:String x:Key="hidden_mode_serial_change">Cambia numero di serie</sys:String>
    <sys:String x:Key="hidden_mode_serial_change_desc">Cambia il numero di serie del dispositivo di destinazione corrente</sys:String>
    <sys:String x:Key="hidden_mode_did_change">Cambia numero DID e colore</sys:String>
    <sys:String x:Key="hidden_mode_did_change_desc">Cambia l'ID del modello del dispositivo di destinazione corrente</sys:String>
    <sys:String x:Key="hidden_mode_sku_change">Cambia codice SKU</sys:String>
    <sys:String x:Key="hidden_mode_sku_change_desc">Cambia il codice prodotto del dispositivo di destinazione corrente</sys:String>
    <sys:String x:Key="hidden_mode_bt_peer_addr_change">Cambia indirizzo Bluetooth del peer</sys:String>
    <sys:String x:Key="hidden_mode_bt_peer_change_desc">Cambia l'indirizzo Bluetooth del peer del dispositivo di destinazione corrente</sys:String>
