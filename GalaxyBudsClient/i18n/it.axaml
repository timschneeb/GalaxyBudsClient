    <sys:String x:Key="hidden_mode_terminal_desc">Invia comandi AT personalizzati al dispositivo di destinazione corrente</sys:String>

    <sys:String x:Key="power_menu_hint">Le modifiche avranno effetto solo sull'auricolare di destinazione corrente.</sys:String>
