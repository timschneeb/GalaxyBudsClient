    <!--Settings >>> Connection popup-->
    <sys:String x:Key="settings_cpopup_header">Popup di connessione</sys:String>
    <sys:String x:Key="settings_cpopup_enable">Abilita popup alla connessione</sys:String>
    <sys:String x:Key="settings_cpopup_enable_description">Mostra una piccola notifica popup con i livelli di batteria quando vengono connessi gli auricolari</sys:String>
    <sys:String x:Key="settings_cpopup_compact">Modalità compatta</sys:String>
    <sys:String x:Key="settings_cpopup_compact_description">Nascondi l'intestazione del popup per risparmiare spazio</sys:String>
