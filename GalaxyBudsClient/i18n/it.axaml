    <!--Device selection page (setup)-->
    <sys:String x:Key="devsel_header">Seleziona i tuoi Galaxy Buds</sys:String>
    <sys:String x:Key="devsel_manual_pair_title">Il tuo dispositivo non è in elenco?</sys:String>
    <sys:String x:Key="devsel_manual_pair_description">Assicurati che i tuoi auricolari siano già stati accoppiati. Se non vengono ancora riconosciuti, prova a usare la connessione manuale.</sys:String>
    <sys:String x:Key="devsel_manual_pair">Connessione manuale</sys:String>
    <sys:String x:Key="devsel_nodevices">Connetti e accoppia i tuoi auricolari prima</sys:String>
    <sys:String x:Key="devsel_nodevices_title">Nessun dispositivo accoppiato trovato</sys:String>
    <sys:String x:Key="devsel_invalid_selection">Seleziona un dispositivo valido</sys:String>
    <sys:String x:Key="devsel_winrt_title">Usa backend Bluetooth alternativo</sys:String>
    <sys:String x:Key="devsel_winrt">Stabilità decisamente migliore, ma potrebbe non funzionare su tutti i PC con alcuni adattatori Bluetooth (Potrebbe essere richiesto un riavvio!)</sys:String>

